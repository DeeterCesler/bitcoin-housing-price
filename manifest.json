{
  "manifest_version": 3,
  "name": "Home Prices in Bitcoin",
  "version": "1.0.0",
  "description": "Shows Zillow housing prices in Bitcoin. Click the toggle next to any price to flip between BTC and USD.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://www.zillow.com/*",
    "https://api.coingecko.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.zillow.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Home Prices in Bitcoin",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
